<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Keylab Performance Parties 2026 — Program</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --cream: #faf8f4;
  --paper: #f4f1eb;
  --ink:   #1a1a16;
  --ink2:  #3a3a34;
  --ink3:  #6e6e64;
  --rule:  #c8c4b8;
  --rule2: #e0dcd4;
  --acc:   #8b1a1a;
  --cvp:   #5a3e8a;
  --sans:  "DM Sans", sans-serif;
  --serif: "EB Garamond", Georgia, serif;
}

body {
  background: var(--cream);
  color: var(--ink);
  font-family: var(--serif);
  font-size: 17px;
  line-height: 1.6;
  min-height: 100vh;
}

/* ── Header ── */
.masthead {
  border-bottom: 3px double var(--ink);
  padding: 2rem 1.5rem 1.25rem;
  text-align: center;
  background: var(--cream);
}
.masthead-eyebrow {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--ink3);
  margin-bottom: .6rem;
}
.masthead-title {
  font-family: var(--serif);
  font-size: clamp(28px, 6vw, 46px);
  font-weight: 500;
  line-height: 1.1;
  letter-spacing: -.01em;
  color: var(--ink);
  margin-bottom: .4rem;
}
.masthead-sub {
  font-family: var(--sans);
  font-size: 12px;
  color: var(--ink3);
  letter-spacing: .06em;
}

/* ── Day tabs ── */
.day-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--paper);
  border-bottom: 1.5px solid var(--rule);
  padding: 0 1rem;
  display: flex;
  gap: 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.day-nav::-webkit-scrollbar { display: none; }
.day-tab {
  flex-shrink: 0;
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: .05em;
  text-transform: uppercase;
  color: var(--ink3);
  padding: .75rem 1.1rem;
  border: none;
  border-bottom: 2.5px solid transparent;
  background: transparent;
  cursor: pointer;
  transition: color .15s, border-color .15s;
  white-space: nowrap;
}
.day-tab:hover { color: var(--ink); }
.day-tab.active {
  color: var(--acc);
  border-bottom-color: var(--acc);
  font-weight: 600;
}

/* ── Content ── */
.content {
  max-width: 680px;
  margin: 0 auto;
  padding: 2rem 1.5rem 4rem;
}

/* ── Day section ── */
.day-section { display: none; }
.day-section.visible { display: block; }

.day-header {
  text-align: center;
  padding: 2rem 0 1.5rem;
  border-bottom: 1px solid var(--rule);
  margin-bottom: 2rem;
}
.day-header-name {
  font-family: var(--serif);
  font-size: clamp(22px, 4vw, 32px);
  font-weight: 500;
  letter-spacing: -.01em;
  color: var(--ink);
}
.day-header-date {
  font-family: var(--sans);
  font-size: 12px;
  color: var(--ink3);
  letter-spacing: .08em;
  text-transform: uppercase;
  margin-top: .3rem;
}

/* ── Segment group ── */
.segment-group { margin-bottom: 2.5rem; }
.segment-label {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--ink3);
  padding-bottom: .5rem;
  border-bottom: 1px solid var(--rule2);
  margin-bottom: 1.5rem;
}

/* ── Performer entry ── */
.performer {
  margin-bottom: 2.25rem;
  padding-bottom: 2.25rem;
  border-bottom: 1px solid var(--rule2);
}
.performer:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.performer-name {
  font-family: var(--serif);
  font-size: clamp(18px, 3.5vw, 22px);
  font-weight: 600;
  line-height: 1.2;
  color: var(--ink);
  margin-bottom: .2rem;
}
.performer-meta {
  font-family: var(--sans);
  font-size: 12px;
  color: var(--ink3);
  margin-bottom: .6rem;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: .4rem;
}
.performer-instrument {
  font-weight: 500;
  color: var(--ink2);
}
.cvp-badge {
  font-family: var(--sans);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .06em;
  text-transform: uppercase;
  color: var(--cvp);
  background: #f0ebfe;
  border: 1px solid #d0bef8;
  border-radius: 20px;
  padding: 2px 8px;
}
.performer-teacher {
  font-family: var(--sans);
  font-size: 12.5px;
  color: var(--ink3);
  margin-bottom: .75rem;
}
.performer-teacher em {
  font-style: normal;
  color: var(--ink2);
  font-weight: 500;
}

.songs {
  margin-bottom: .85rem;
}
.song-line {
  font-family: var(--serif);
  font-size: 16px;
  color: var(--ink);
  line-height: 1.45;
  padding-left: 1.1rem;
  position: relative;
}
.song-line::before {
  content: '\2022';
  position: absolute;
  left: 0;
  color: var(--acc);
}
.song-title {
  font-style: italic;
}
.song-composer {
  color: var(--ink3);
  font-size: 14px;
}
.song-line + .song-line {
  margin-top: .3rem;
}

.program-notes {
  font-family: var(--serif);
  font-size: 15.5px;
  line-height: 1.65;
  color: var(--ink2);
  font-style: italic;
}
.program-notes::before {
  content: '\201C';
  color: var(--ink3);
}
.program-notes::after {
  content: '\201D';
  color: var(--ink3);
}

/* ── Loading / error ── */
.state-msg {
  text-align: center;
  padding: 4rem 1rem;
  font-family: var(--sans);
  color: var(--ink3);
  font-size: 14px;
}
.state-msg .spinner {
  display: inline-block;
  width: 24px;
  height: 24px;
  border: 2px solid var(--rule);
  border-top-color: var(--ink3);
  border-radius: 50%;
  animation: spin .7s linear infinite;
  margin-bottom: 1rem;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── Footer ── */
.footer {
  text-align: center;
  padding: 2rem 1rem;
  border-top: 1px solid var(--rule);
  font-family: var(--sans);
  font-size: 11px;
  color: var(--ink3);
  letter-spacing: .05em;
}

@media print {
  .day-nav { display: none; }
  .day-section { display: block !important; }
  .performer { break-inside: avoid; }
}
</style>
</head>
<body>

<div class="masthead">
  <div class="masthead-eyebrow">Keylab Music School &middot; 94 Luquer St, Brooklyn</div>
  <div class="masthead-title">Performance Parties 2026</div>
  <div class="masthead-sub">June 15&ndash;19 &middot; Program</div>
</div>

<nav class="day-nav" id="dayNav"></nav>

<div class="content" id="content">
  <div class="state-msg" id="stateMsg">
    <div class="spinner"></div><br>Loading program&hellip;
  </div>
</div>

<div class="footer">Keylab Music School &middot; keylab.nyc</div>

<script>
var GAS_URL = 'https://script.google.com/macros/s/AKfycbzenlfK9eu0G17af-fdjrkiRT-qZLcsLByN-QGb_SCIpmev_xoI3PkY6OW92nuiz4L45g/exec';
var DAY_ORDER  = ['Monday','Tuesday','Wednesday','Thursday','Friday'];
var DAY_DATES  = {Monday:'June 15',Tuesday:'June 16',Wednesday:'June 17',Thursday:'June 18',Friday:'June 19'};
var SEG_ORDER  = ['Early','Single','Late'];
var SEG_LABELS = {Early:'Early Session',Single:'Single Session',Late:'Late Session'};
var activeDay  = null;

function api(payload, cb) {
  fetch(GAS_URL, {
    method: 'POST',
    headers: {'Content-Type': 'text/plain'},
    body: JSON.stringify(payload)
  })
  .then(function(res) { return res.json(); })
  .then(function(r)   { cb(null, r); })
  .catch(function(e)  { cb(String(e)); });
}

function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function buildInstrumentLabel(p) {
  var i1 = (p.instrument  || '').trim();
  var i2 = (p.instrument2 || '').trim();
  if (!i1 && !i2) return '';
  if (!i2 || i1.toLowerCase() === i2.toLowerCase()) return i1;
  return i1 + ', ' + i2;
}

function buildTeacherLabel(p) {
  var t1 = (p.teacherFull  || '').trim();
  var t2 = (p.teacherFull2 || '').trim();
  if (!t1 && !t2) return '';
  if (!t2) return t1;
  if (!t1) return t2;
  return t1 + ' &amp; ' + t2;
}

function renderPerformer(p) {
  var isCvp = p.status === 'confirmed-video';
  var instr  = buildInstrumentLabel(p);
  var teacher = buildTeacherLabel(p);

  var h = '<div class="performer">';

  // Name
  h += '<div class="performer-name">' + esc(p.name) + '</div>';

  // Instrument + CVP badge
  h += '<div class="performer-meta">';
  if (instr) h += '<span class="performer-instrument">' + esc(instr) + '</span>';
  if (isCvp) h += '<span class="cvp-badge">Video Performance</span>';
  h += '</div>';

  // Teacher
  if (teacher) {
    h += '<div class="performer-teacher">Teacher: <em>' + teacher + '</em></div>';
  }

  // Songs
  var hasSong1 = (p.song1Title || '').trim();
  var hasSong2 = (p.song2Title || '').trim();
  if (hasSong1 || hasSong2) {
    h += '<div class="songs">';
    if (hasSong1) {
      h += '<div class="song-line">';
      h += '<span class="song-title">' + esc(p.song1Title) + '</span>';
      if ((p.song1Composer || '').trim()) {
        h += ' <span class="song-composer">&mdash; ' + esc(p.song1Composer) + '</span>';
      }
      h += '</div>';
    }
    if (hasSong2) {
      h += '<div class="song-line">';
      h += '<span class="song-title">' + esc(p.song2Title) + '</span>';
      if ((p.song2Composer || '').trim()) {
        h += ' <span class="song-composer">&mdash; ' + esc(p.song2Composer) + '</span>';
      }
      h += '</div>';
    }
    h += '</div>';
  }

  // Program notes (song1Info first, then song2Info if different)
  var notes1 = (p.song1Info || '').trim();
  var notes2 = (p.song2Info || '').trim();
  var notes  = notes1;
  if (notes2 && notes2 !== notes1) notes = notes1 ? notes1 + ' ' + notes2 : notes2;
  if (notes) {
    h += '<div class="program-notes">' + esc(notes) + '</div>';
  }

  h += '</div>';
  return h;
}

function renderDay(dayPerformers, day) {
  // Group by segment
  var bySegment = {};
  dayPerformers.forEach(function(p) {
    var seg = p.segment || 'Single';
    if (!bySegment[seg]) bySegment[seg] = [];
    bySegment[seg].push(p);
  });

  var segs = SEG_ORDER.filter(function(s) { return bySegment[s] && bySegment[s].length; });
  // Also catch any unexpected segment values
  Object.keys(bySegment).forEach(function(s) {
    if (segs.indexOf(s) === -1) segs.push(s);
  });

  var h = '<div class="day-header">';
  h += '<div class="day-header-name">' + esc(day) + '</div>';
  h += '<div class="day-header-date">' + esc(DAY_DATES[day] || '') + '</div>';
  h += '</div>';

  segs.forEach(function(seg) {
    var group = bySegment[seg];
    if (!group || !group.length) return;
    h += '<div class="segment-group">';
    // Only show segment label if more than one segment on this day
    if (segs.length > 1) {
      h += '<div class="segment-label">' + esc(SEG_LABELS[seg] || seg) + '</div>';
    }
    group.forEach(function(p) { h += renderPerformer(p); });
    h += '</div>';
  });

  return h;
}

function showDay(day) {
  activeDay = day;
  document.querySelectorAll('.day-tab').forEach(function(t) {
    t.classList.toggle('active', t.dataset.day === day);
  });
  document.querySelectorAll('.day-section').forEach(function(s) {
    s.classList.toggle('visible', s.dataset.day === day);
  });
}

function render(performers) {
  // Group by day
  var byDay = {};
  performers.forEach(function(p) {
    var d = p.day || 'Unscheduled';
    if (!byDay[d]) byDay[d] = [];
    byDay[d].push(p);
  });

  var days = DAY_ORDER.filter(function(d) { return byDay[d] && byDay[d].length; });
  // Catch any unlisted days
  Object.keys(byDay).forEach(function(d) {
    if (days.indexOf(d) === -1) days.push(d);
  });

  if (!days.length) {
    document.getElementById('stateMsg').style.display = 'block';
    document.getElementById('stateMsg').innerHTML = 'No performers confirmed yet.';
    return;
  }

  // Build nav tabs
  var nav = document.getElementById('dayNav');
  nav.innerHTML = days.map(function(d) {
    return '<button class="day-tab" data-day="' + esc(d) + '" onclick="showDay(\'' + esc(d) + '\')">' +
           esc(d) + (DAY_DATES[d] ? '<br><span style="font-size:10px;opacity:.7">' + esc(DAY_DATES[d]) + '</span>' : '') +
           '</button>';
  }).join('');

  // Build content sections
  var content = document.getElementById('content');
  content.innerHTML = days.map(function(d) {
    return '<div class="day-section" data-day="' + esc(d) + '">' + renderDay(byDay[d], d) + '</div>';
  }).join('');

  // Show first day
  showDay(days[0]);
}

// Load
api({action: 'getProgram'}, function(err, r) {
  var msg = document.getElementById('stateMsg');
  if (err || !r || !r.ok) {
    msg.innerHTML = 'Could not load program. Please refresh and try again.';
    return;
  }
  msg.style.display = 'none';
  render(r.performers || []);
});
</script>
</body>
</html>
